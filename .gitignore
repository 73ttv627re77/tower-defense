# System/tool-specific ignores
.directory
*~

# iOS / Xcode build artifacts
ios/build/
ios/Pods/
ios/*.xcworkspace/xcuserdata/
ios/*.xcodeproj/xcuserdata/
ios/*.xcodeproj/project.xcworkspace/xcuserdata/
ios/Export/

# Local config
.env
.env.local

# Editor noise
*.swp
*.swo
.DS_Store
